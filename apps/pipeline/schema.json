{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gang Organization",
  "description": "Schema for a gang.guide org file in data/orgs/",
  "type": "object",
  "required": ["id", "name", "type", "lane", "description", "founded_year", "sources"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^org:[a-z0-9][a-z0-9-]*$",
      "description": "Unique identifier in format org:slug-name"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "description": "Display name of the organization"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "maxLength": 60 },
      "default": [],
      "description": "Alternative names, abbreviations"
    },
    "type": {
      "type": "string",
      "enum": ["street_gang", "organized_crime", "motorcycle_club", "prison_gang", "white_supremacist", "alliance", "nation"],
      "description": "Organization type"
    },
    "lane": {
      "type": "string",
      "description": "Lane ID for timeline positioning (must match lanes.json)"
    },
    "metro": {
      "type": "string",
      "description": "Primary metropolitan area"
    },
    "description": {
      "type": "string",
      "minLength": 50,
      "description": "Factual 1-3 sentence description"
    },
    "founded_year": {
      "type": "integer",
      "minimum": 1800,
      "maximum": 2026,
      "description": "Year the organization was founded"
    },
    "founded_year_precision": {
      "type": "string",
      "enum": ["exact", "circa", "decade", "estimate", "range"],
      "description": "How precise the founding year is"
    },
    "colors": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "Gang colors"
    },
    "symbols": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Gang symbols and identifiers"
    },
    "nation_affiliation": {
      "type": ["string", "null"],
      "pattern": "^org:[a-z0-9-]+$",
      "description": "Parent nation org ID (e.g. org:crips, org:folk-nation)"
    },
    "status": {
      "type": "string",
      "enum": ["active", "inactive"],
      "description": "Whether the organization is currently active"
    },
    "disbanded_year": {
      "type": ["integer", "null"],
      "minimum": 1800,
      "maximum": 2026,
      "description": "Year the organization disbanded (if inactive)"
    },
    "membership_estimate": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Estimated membership count"
    },
    "membership_year": {
      "type": ["integer", "null"],
      "description": "Year the membership estimate is from"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "title"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string", "minLength": 1 }
        }
      },
      "description": "Source references with URL and title"
    }
  },
  "additionalProperties": false
}
